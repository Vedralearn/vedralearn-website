# VedraLearn Admin Backend - Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to git! Add it to .gitignore

# ============================================
# SERVER CONFIGURATION
# ============================================

# Server port for local development
PORT=5000

# Environment: development, staging, or production
NODE_ENV=development

# ============================================
# JWT CONFIGURATION
# ============================================

# SECRET KEY FOR JWT TOKENS
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Change this value in production!
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345

# JWT expiration time
JWT_EXPIRY=24h

# ============================================
# DATABASE CONFIGURATION (LOCAL)
# ============================================

# For LOCAL MySQL (during development)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_local_password
# DB_NAME=vedralearn_admin

# ============================================
# DATABASE CONFIGURATION (AWS RDS)
# ============================================

# For AWS RDS MySQL
# Get RDS endpoint from AWS Console > RDS > Databases > vedralearn-admin-db > Endpoint
DB_HOST=vedralearn-admin-db.c9akciq32.us-east-1.rds.amazonaws.com
DB_PORT=3306
DB_USER=vedralearn_app
DB_PASSWORD=your_strong_rds_password_here
DB_NAME=vedralearn_admin

# Database type: mysql, postgresql, or dynamodb (default: mysql)
DB_TYPE=mysql

# Enable SSL for database connection (recommended for RDS)
DB_SSL=false

# ============================================
# AWS CONFIGURATION
# ============================================

# AWS Region
AWS_REGION=us-east-1

# AWS Access Key (Use IAM roles instead of hardcoding keys in production!)
AWS_ACCESS_KEY_ID=AKIA2EXAMPLE1234567
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/EXAMPLEKEY

# ============================================
# CORS CONFIGURATION
# ============================================

# Allow requests from this origin
# Development: http://localhost:3000
# Production: https://your-domain.com
CORS_ORIGIN=http://localhost:3000

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================

# For sending email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
SMTP_FROM=noreply@vedralearn.com

# Enable email notifications
ENABLE_EMAIL_NOTIFICATIONS=false

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log level: error, warn, info, debug
LOG_LEVEL=info

# Enable file logging
LOG_TO_FILE=false
LOG_FILE_PATH=./logs/app.log

# ============================================
# SECURITY CONFIGURATION
# ============================================

# Rate limiting (requests per hour)
RATE_LIMIT_PER_HOUR=100

# Session timeout (in minutes)
SESSION_TIMEOUT=60

# BCRYPT Salt rounds (higher = more secure but slower)
BCRYPT_ROUNDS=10

# ============================================
# EXTERNAL SERVICES
# ============================================

# Google Cloud Storage (optional)
GCS_PROJECT_ID=
GCS_BUCKET_NAME=

# AWS S3 (optional)
S3_BUCKET_NAME=vedralearn-uploads
S3_REGION=us-east-1

# ============================================
# PAYMENT GATEWAY (Future)
# ============================================

# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLIC_KEY=pk_test_...

# ============================================
# ANALYTICS (Optional)
# ============================================

# Google Analytics
GOOGLE_ANALYTICS_ID=

# Sentry Error Tracking
SENTRY_DSN=

# ============================================
# ADMIN CREDENTIALS (Change these!)
# ============================================

# Default admin email
ADMIN_EMAIL=admin@vedralearn.com

# Default admin password (will be hashed)
# Change immediately after first login!
ADMIN_PASSWORD=admin123

# ============================================
# DEVELOPMENT TOOLS
# ============================================

# Enable request logging
REQUEST_LOGGING=true

# Enable database query logging
DB_QUERY_LOGGING=false

# Enable detailed error messages (disable in production!)
DETAILED_ERRORS=true

# ============================================
# NOTES
# ============================================

# 1. NEVER commit this file to git!
#    Add to .gitignore:
#    .env
#    .env.local
#    .env.*.local

# 2. Generate secure JWT_SECRET:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# 3. BCRYPT ROUNDS:
#    8-10: Good for local dev
#    12+: Recommended for production

# 4. DATABASE PASSWORDS:
#    - Use AWS Secrets Manager in production
#    - DO NOT hardcode in .env
#    - Rotate regularly

# 5. AWS CREDENTIALS:
#    - Use IAM roles instead of access keys
#    - Use AWS Secrets Manager
#    - Enable MFA on root account

# 6. GMAIL APP PASSWORD:
#    - Enable 2FA on Gmail
#    - Generate App Specific Password
#    - Use that instead of actual password
